generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  PICKER
  CHEF
  DELIVERY
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  UPI
  CARD
  WALLET
}

enum DiscountType {
  FLAT
  PERCENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  role          Role      @default(USER)
  assignedStoreId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  cart      Cart?
  orders    Order[]
  reviews   Review[]
  deliveryOrders Order[]   @relation("DeliveryOrders")
  pickerOrders   Order[]   @relation("PickerOrders")
  chefOrders     Order[]   @relation("ChefOrders")
  pushSubscriptions PushSubscription[]
  assignedStore  DarkStore? @relation("StoreStaff", fields: [assignedStoreId], references: [id])

  @@map("users")
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  houseNo   String
  street    String
  area      String
  city      String
  pincode   String
  phone     String  @default("")
  lat       Float?
  lng       Float?
  isDefault Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  imageUrl  String?
  parentId  String?
  sortOrder Int     @default(0)

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]
  coupons  Coupon[]

  @@map("categories")
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  imageUrl    String?
  categoryId  String
  mrp         Float
  price       Float
  discount    Float     @default(0)
  unit        String
  stock       Int       @default(0)
  isAvailable Boolean   @default(true)
  tags        String[]
  variants    Json?
  minStock    Int       @default(10)
  expiryDate  DateTime?
  costPrice   Float     @default(0)
  location    String?
  isFlashDeal  Boolean   @default(false)
  isTopPick    Boolean   @default(false)
  isBestSeller Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category     Category       @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  reviews      Review[]
  stockAlerts  StockAlert[]
  priceHistory PriceHistory[]
  batches      ProductBatch[]
  inventories  StoreInventory[]

  @@index([categoryId])
  @@index([name])
  @@index([slug])
  @@index([isAvailable])
  @@index([isFlashDeal])
  @@index([isBestSeller])
  @@index([isTopPick])
  @@index([createdAt])
  @@map("products")
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id              String  @id @default(cuid())
  cartId          String
  productId       String
  quantity        Int     @default(1)
  selectedVariant String?
  notes           String?

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, selectedVariant])
  @@map("cart_items")
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  addressId         String
  combinedId        String?

  status            OrderStatus   @default(PENDING)
  subtotal          Float
  discount          Float         @default(0)
  deliveryFee       Float         @default(0)
  taxes             Float         @default(0)
  miscFee           Float         @default(0)
  total             Float
  paymentMethod     PaymentMethod @default(COD)
  paymentStatus     PaymentStatus @default(PENDING)
  estimatedDelivery DateTime?
  deliveryPhoto     String?
  deliveryLat       Float?
  deliveryLng       Float?
  deliveryMethod    String        @default("DELIVERY")
  isB2B             Boolean       @default(false)
  shopName          String?
  shopPhone         String?
  storeId           String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  confirmedAt       DateTime?
  packedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  notes             String?
  couponCode        String?

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  store   DarkStore?  @relation(fields: [storeId], references: [id])
  
  deliveryUserId String?
  deliveryUser   User?      @relation("DeliveryOrders", fields: [deliveryUserId], references: [id])
  assignedPickerId String?
  assignedPicker   User?      @relation("PickerOrders", fields: [assignedPickerId], references: [id])
  assignedChefId   String?
  assignedChef     User?      @relation("ChefOrders", fields: [assignedChefId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([deliveryUserId])
  @@index([assignedPickerId])
  @@index([assignedChefId])
  @@index([storeId])
  @@index([combinedId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  name            String
  price           Float
  quantity        Int
  imageUrl        String?
  selectedVariant String?
  costPrice       Float    @default(0)
  variants        Json?
  notes           String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  discountType    DiscountType
  value           Float
  minOrder        Float        @default(0)
  maxDiscount     Float?
  maxUses         Int?
  usedCount       Int          @default(0)
  isActive        Boolean      @default(true)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  categoryId      String?
  oncePerCustomer Boolean      @default(false)

  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("coupons")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

model StockAlert {
  id        String   @id @default(cuid())
  productId String
  alertType String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isRead])
  @@map("stock_alerts")
}

model PriceHistory {
  id         String   @id @default(cuid())
  productId  String
  oldPrice   Float
  newPrice   Float
  oldMrp     Float
  newMrp     Float
  changeType String
  changedBy  String?
  batchId    String?
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([batchId])
  @@map("price_history")
}

model ProductBatch {
  id          String   @id @default(cuid())
  productId   String
  batchCode   String
  quantity    Int      // Current stock in this batch
  initialQty  Int      // Original stock when received
  costPrice   Float    // Purchase cost of this batch
  expiryDate  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([expiryDate])
  @@map("product_batches")
}

model PromoBanner {
  id          String   @id @default(cuid())
  title       String
  description String
  code        String
  gradient    String   @default("from-primary via-rose-500 to-orange-400")
  type        String   @default("custom") // e.g. festival, first-order, fresh, snacks
  imageUrl    String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("promo_banners")
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("store_settings")
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otp_tokens")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model PushNotification {
  id           String   @id @default(cuid())
  title        String
  body         String
  imageUrl     String?
  linkUrl      String?
  sentAt       DateTime @default(now())
  successCount Int      @default(0)
  failureCount Int      @default(0)

  @@map("push_notifications")
}

model DarkStore {
  id              String   @id @default(cuid())
  name            String
  latitude        Float
  longitude       Float
  deliveryPolygon Json?    // Array of lat/lng coordinates defining the geofence
  isActive        Boolean  @default(true)
  surgeCharge     Float    @default(0.0)
  groceryOpen     Boolean  @default(true)
  cafeOpen        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inventories     StoreInventory[]
  orders          Order[]
  staffMembers    User[]           @relation("StoreStaff")

  @@map("dark_stores")
}

model StoreInventory {
  productId String
  storeId   String
  stock     Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     DarkStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([productId, storeId])
  @@map("store_inventories")
}

model RestaurantPayout {
  id              String   @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  amount          Float
  status          String   @default("PENDING") // PENDING, PAID
  transactionId   String?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("restaurant_payouts")
}

